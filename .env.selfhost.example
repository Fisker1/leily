# ─── Leily Self-Hosted Configuration ─────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.selfhost.example .env
#
# IMPORTANT: Never commit .env — it is gitignored.

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-db-password
POSTGRES_PORT=5432

# ─── JWT (used by GoTrue, PostgREST, Kong, Edge Functions) ──
# Generate these once and keep them. All three values must match.
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=your-jwt-secret-at-least-32-characters
JWT_EXP=3600

# ─── Supabase API Keys ──────────────────────────────────────
# Generate with the JWT_SECRET above. See README for generation script.
ANON_KEY=your-anon-key-jwt
SERVICE_ROLE_KEY=your-service-role-key-jwt

# ─── URLs ────────────────────────────────────────────────────
# API_EXTERNAL_URL = where the browser reaches the Kong gateway
# SITE_URL         = where the browser reaches the frontend
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000

# ─── Studio (optional admin panel) ──────────────────────────
STUDIO_PORT=54323

# ─── Auth Settings ───────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_SIGN_INS=false
ADDITIONAL_REDIRECT_URLS=

# ─── SMTP (optional — for email confirmations/invites) ──────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@leily.local
SMTP_SENDER_NAME=Leily

# ─── Edge Function Secrets ───────────────────────────────────
# Only fill in the ones you actually use.
OPENAI_API_KEY=
MAPBOX_PUBLIC_TOKEN=

# Microsoft Graph (for send-leily-email function)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_EMAIL_USER=

# Email (for lease notifications)
RESEND_API_KEY=

# E-signing providers
SIGNICAT_CLIENT_ID=
SIGNICAT_CLIENT_SECRET=
SCRIVE_CLIENT_ID=
SCRIVE_CLIENT_SECRET=
