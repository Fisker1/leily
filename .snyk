# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0

# Ignore specific vulnerabilities (use sparingly and document why)
ignore:
  SNYK-JS-XLSX-6252523:
    - '*':
        reason: Using xlsx only for workbook generation (write/writeFile). No parsing of untrusted input; no Snyk fix available. Temporary ignore while monitoring upstream.
        expires: '2026-01-31T23:59:59.000Z'

# Patch specific vulnerabilities
# patch:
#   SNYK-JS-LODASH-567746:
#     - lodash@4.17.21:
#         patched: '2024-01-01T00:00:00.000Z'

# Language settings
language-settings:
  javascript:
    # Only scan production dependencies by default
    dev-dependencies: false
