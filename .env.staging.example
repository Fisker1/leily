# Staging Environment Configuration
# Copy this to .env for staging deployment

# Environment identifier
VITE_ENVIRONMENT=staging

# Staging Supabase Configuration
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-staging-anon-key
VITE_SUPABASE_PROJECT_ID=your-staging-project-id

# Staging App Configuration
VITE_APP_URL=https://staging.leily.no

# Feature flags for staging
VITE_ENABLE_ANALYTICS=false
VITE_DEBUG=true
VITE_LOG_LEVEL=debug