+              <p className="text-xs text-muted-foreground truncate">{subtitle}</p>
+            )}
+          </div>
+          <div className="flex items-center gap-2 ml-3 flex-shrink-0">
+            {actions}
+            <Link
+              to="/innstillinger"
+              className={cn(
+                "p-2 rounded-lg transition-colors",
