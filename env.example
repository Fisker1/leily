# Environment Configuration for Leily Application
# Copy this file to .env and fill in your actual values

# Application Environment
VITE_ENVIRONMENT=development
VITE_APP_URL=http://localhost:8080
VITE_DEBUG=true
VITE_COMING_SOON=false

# Supabase Configuration (EU Region)
VITE_SUPABASE_URL=https://wdwjmapvuibsqiifslno.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PROJECT_ID=wdwjmapvuibsqiifslno

# Analytics Configuration
VITE_ENABLE_ANALYTICS=false

# OAuth Configuration (if using custom OAuth providers)
# VITE_GOOGLE_CLIENT_ID=your_google_client_id
# VITE_GITHUB_CLIENT_ID=your_github_client_id

# Email Configuration (if using custom email service)
# VITE_EMAIL_SERVICE_URL=your_email_service_url
# VITE_EMAIL_API_KEY=your_email_api_key

# External API Keys (if needed)
# VITE_MAPBOX_TOKEN=your_mapbox_token
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Development Database (for local development)
POSTGRES_DB=leily_dev
POSTGRES_USER=leily
POSTGRES_PASSWORD=leily_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Docker Configuration
COMPOSE_PROJECT_NAME=leily

