# Copy to .env and fill in values from Supabase dashboard
# Never commit .env — it is gitignored

VITE_ENVIRONMENT=staging            # staging | production
VITE_SUPABASE_URL=                  # https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=             # anon key from Supabase dashboard
VITE_SUPABASE_PROJECT_ID=           # project ID
VITE_APP_URL=                       # https://stage.leily.no or https://www.leily.no
VITE_COMING_SOON=false              # true to show coming-soon page
VITE_ENABLE_ANALYTICS=false         # true to enable Vercel Analytics
VITE_DEBUG=false                    # true to enable debug logging
