# Environment Configuration Template
# Copy this to .env.local and fill in your actual values
# NEVER commit .env.local or actual secrets to version control

# Application Environment
VITE_ENVIRONMENT=development
# Options: development, staging, production

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Application URLs
VITE_APP_URL=http://localhost:8080
# Use your actual domain in production: https://yourdomain.com

# Optional Features
VITE_ENABLE_ANALYTICS=false
VITE_DEBUG=true
VITE_LOG_LEVEL=debug
VITE_COMING_SOON=false

# Supabase Edge Function Secrets (Set in Supabase Dashboard -> Settings -> Edge Functions)
# MAPBOX_PUBLIC_TOKEN=pk.your-mapbox-public-token-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Security Notes:
# - VITE_ prefixed variables are exposed to the client
# - Never put private keys or secrets in VITE_ variables
# - Use Supabase Edge Function secrets for sensitive tokens
# - Always use HTTPS in production
# - Set VITE_ENVIRONMENT=production for production builds